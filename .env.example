GEMINI_API_KEY=your-gemini-api-key-here
SECRET_KEY=your-flask-secret-key-here
DEBUG=True
UPLOAD_FOLDER=uploads

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#  EMAIL OTP — PROVIDER 1: Gmail SMTP  (RECOMMENDED — FREE)
#  Setup (2 minutes):
#    1. myaccount.google.com → Security → 2-Step Verification → ON
#    2. myaccount.google.com → Security → App passwords
#    3. App name: GrivoraAI → Generate → copy 16-char code
#    4. Fill SMTP_USER and SMTP_PASSWORD below (no spaces in password)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#  EMAIL OTP — PROVIDER 2: SendGrid  (100 free emails/day)
#  Setup: sendgrid.com → Settings → API Keys → Create API Key
#         Permission: Mail Send → Full Access
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
SENDGRID_API_KEY=
SENDGRID_FROM=

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#  EMAIL OTP — PROVIDER 3: Mailgun  (1000 free emails/month)
#  Setup: mailgun.com → Sending → Domains → Add Domain
#         API Keys → create Private API Key
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
MAILGUN_API_KEY=
MAILGUN_DOMAIN=
MAILGUN_FROM=
MAILGUN_REGION=us

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#  MOBILE OTP — Twilio SMS
#  Setup: twilio.com → Console → Account SID & Auth Token
#         Phone Numbers → Buy a number (trial is FREE)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
TWILIO_SID=
TWILIO_TOKEN=
TWILIO_FROM=

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#  GOOGLE OAUTH (Sign in with Google)
#  Setup: console.cloud.google.com
#         APIs & Services → Credentials → Create OAuth 2.0 Client
#         Authorized redirect URI: http://localhost:5000/auth/google/callback
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#  SUPPORT EMAIL (shown in OTP email footer)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
SUPPORT_EMAIL=support@grivora.ai
